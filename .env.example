# =============================================================================
# Database (Neon - Serverless PostgreSQL)
# =============================================================================
# 1. Create a free project at https://neon.tech
# 2. Copy the "Connection string" from your Neon dashboard (Pooled connection
#    recommended for serverless/production, direct connection for migrations)
# 3. Neon connection strings look like:
#    postgresql://<user>:<password>@<host>.neon.tech/<database>?sslmode=require
#
# DATABASE_URL is used by Prisma Client at runtime (use the pooled connection,
# adding "&pgbouncer=true" if you use Neon's pooled endpoint).
DATABASE_URL="postgresql://neondb_owner:password@ep-example-12345.us-east-2.aws.neon.tech/neondb?sslmode=require"

# DIRECT_URL is used by Prisma Migrate to run migrations (use Neon's direct,
# non-pooled connection string here). If you only have one connection string,
# you can set DIRECT_URL to the same value as DATABASE_URL.
DIRECT_URL="postgresql://neondb_owner:password@ep-example-12345.us-east-2.aws.neon.tech/neondb?sslmode=require"

# =============================================================================
# JWT Authentication
# =============================================================================
JWT_SECRET="replace-this-with-a-long-random-secret-string"
JWT_EXPIRES_IN="1d"

# =============================================================================
# App
# =============================================================================
PORT=3000
NODE_ENV=development

# Seed admin account (used only by prisma/seed.ts)
ADMIN_EMAIL="admin@infnova.com"
ADMIN_PASSWORD="Admin123!"
